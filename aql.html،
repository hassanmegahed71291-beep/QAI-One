<body>
  <!-- القائمة الجانبية -->
  <aside class="sidebar">
    <div class="logo">
      <h2>QUALIO</h2>
    </div>
    <ul class="menu">
      <li><a href="index.html">🏠 الرئيسية</a></li>
      <li><a href="academy.html">🎓 قسم التعلّم</a></li>
      <li><a href="aql.html" class="active">📊 قسم AQL</a></li>
