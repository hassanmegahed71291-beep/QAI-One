<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QUALIO - قسم التعلّم</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <!-- القائمة الجانبية -->
  <aside class="sidebar">
    <div class="logo">
      <h2>QUALIO</h2>
    </div>
    <ul class="menu">
      <li><a href="index.html">🏠 الرئيسية</a></li>
      <li><a href="academy.html" class="active">🎓 قسم التعلّم</a></li>
      <li><a href="aql.html">📊 قسم AQL</a></li>
      <li><a href="reports.html">📑 التقارير</a></li>
      <li><a href="community.html">👥 المجتمع</a></li>
      <li><a href="suppliers.html">🏭 الموردين</a></li>
      <li><a href="users.html">👤 المستخدمين</a></li>
      <li><a href="settings.html">⚙️ الإعدادات</a></li>
    </ul>
  </aside>

  <!-- المحتوى الرئيسي -->
  <main class="content">
    <header>
      <h1>🎓 قسم التعلّم</h1>
      <p>رحلة الجودة من المبتدئ إلى القائد</p>
    </header>

    <!-- المسارات التعليمية -->
    <section class="dashboard">
      <div class="card">
        <h3>🔰 المبتدئ</h3>
        <p>تعلم أساسيات الجودة مثل PDCA و5S.</p>
        <button onclick="addPoints(10)">ابدأ الآن</button>
      </div>
      <div class="card">
        <h3>📈 المتوسط</h3>
        <p>أدوات الجودة مثل Pareto وFishbone وSPC.</p>
        <button onclick="addPoints(20)">ابدأ الآن</button>
      </div>
      <div class="card">
        <h3>🚀 المتقدم</h3>
        <p>إدارة الجودة الشاملة، Six Sigma، Lean.</p>
        <button onclick="addPoints(30)">ابدأ الآن</button>
      </div>
      <div class="card">
        <h3>👑 القائد</h3>
        <p>قيادة فرق الجودة، التدقيق، التحضير للشهادات العالمية.</p>
        <button onclick="addPoints(50)">ابدأ الآن</button>
      </div>
    </section>

    <!-- محاكاة تدريبية -->
    <section class="dashboard">
      <div class="card">
        <h3>📞 محاكاة مع عميل</h3>
        <p>تدريب على كيفية التعامل مع عميل غاضب أو متردد.</p>
        <button onclick="simulationScenario('client')">ابدأ المحاكاة</button>
      </div>
      <div class="card">
        <h3>👔 محاكاة مع مدير</h3>
        <p>تدريب على كيفية الرد على المدير تحت ضغط.</p>
        <button onclick="simulationScenario('manager')">ابدأ المحاكاة</button>
      </div>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
